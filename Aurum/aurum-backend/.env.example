# ── SERVER ──────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── DATABASE (MongoDB Atlas free tier) ───────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/aurum?retryWrites=true&w=majority

# ── JWT SECRET (generate with: openssl rand -hex 64) ─
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ── ADMIN CREDENTIALS (first-time setup) ─────────────
ADMIN_EMAIL=admin@aurum-ristorante.com
ADMIN_PASSWORD=AurumAdmin2026!

# ── EMAIL (use Gmail App Password or SendGrid) ────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM="Aurum Ristorante <reservations@aurum-ristorante.com>"
NOTIFY_EMAIL=owner@aurum-ristorante.com

# ── FRONTEND URL (for CORS) ───────────────────────────
FRONTEND_URL=https://your-frontend-url.com

# ── FILE UPLOADS ──────────────────────────────────────
MAX_FILE_SIZE_MB=5
UPLOAD_PATH=./uploads
